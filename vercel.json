{
  "buildCommand": "pnpm run build && node_modules/.bin/esbuild server/vercel-handler.ts --platform=node --packages=external --bundle --format=esm --outfile=api/index.js",
  "outputDirectory": "dist/public",
  "installCommand": "COREPACK_INTEGRITY_KEYS=0 pnpm install",
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/trpc/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
